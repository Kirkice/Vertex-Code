{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "react-jsx",
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"noFallthroughCasesInSwitch": true,
		"sourceMap": true,

		/* Path aliases */
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"],
			"@src/*": ["./src/*"],
			"@vertex-code/types": ["./src/types-shared/index.ts"],
			"@vertex/*": ["./src/shared/*"]
		}
	},
	"include": ["src"]
}